# WinLab backend environment example.
# Copy to .env and fill real values before running.

# Database. SQLite for local dev.
DATABASE_URL=sqlite:///./chat_data/dev.sqlite
# Folder for SQLite + branding/avatar.jpg.
CHAT_DATA_DIR=chat_data

# Debug mode (1=true, 0=false).
DEBUG=1

# CORS origins for the WinLab frontend dev server (Vite default 5173).
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000"]

# OpenAI key — required for chat and Realtime voice.
OPENAI_API_KEY=

# OpenAI Realtime model and voice.
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_URL=https://api.openai.com/v1/realtime/calls

# Default chat locale and Realtime VAD tuning.
CHATBOT_DEFAULT_LOCALE=ru
# REALTIME_VAD_SILENCE_MS=4000
# REALTIME_VAD_PREFIX_MS=450
# REALTIME_VAD_THRESHOLD=0.48
# REALTIME_INTERRUPT_RESPONSE=0

# Default system prompt for voice chat fallback.
OPENAI_REALTIME_INSTRUCTIONS=You are the WinLab HR Assistant. Greet the employee, answer HR questions only from approved sources, ask for consent before forwarding unresolved questions to a human HR administrator, and never expose payroll or personal data without proper authorization.

# JWT secret for admin auth.
SECRET_KEY=change-me

# Disable recruiting auto-assess loop in WinLab.
ENABLE_AUTO_ASSESS=0

# Backend listen port.
APP_PORT=8000
